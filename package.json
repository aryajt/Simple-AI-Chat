{
  "name": "niksam-chat-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:api": "nest start api",
    "start:ai": "nest start ai-service",
    "start:logger": "nest start logger-service",
    "build:api": "nest build api",
    "build:ai": "nest build ai-service",
    "build:logger": "nest build logger-service",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:cov": "jest --config jest.config.js --coverage --passWithNoTests",
    "test:e2e": "jest --config jest.config.js --testRegex '.e2e-spec.ts$' --passWithNoTests",
    "test:watch": "jest --config jest.config.js --watch"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "typeorm": "^0.3.20",
    "pg": "^8.11.3",
    "nats": "^2.18.0",
    "rxjs": "^7.8.1",
    "reflect-metadata": "^0.2.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "typescript": "^5.3.3",
    "ts-jest": "^29.1.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2",
    "fast-check": "^3.15.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
